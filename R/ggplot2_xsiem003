## packages
install.packages("data.table")
install.packages("ggplot2")

library(data.table)
library(ggplot2)

## loading data
dta <- readRDS("prec_data.rds")

dta_t <- as.data.table(x = dta)

## inspecting things
class(x = dta)                                                                  ## data.frame
class(x = dta_t)                                                                ## data.table, data.frame

names(x = dta_t)                                                                ## STATION ELEMENT DT VALUE FLAG QUALITY X
dim(x = dta_t)                                                                  ## dimensions of the dataset
                                                                                ## a TON of rows with only 7 columns
                                                                                ## could be hard to plot

object.size(x = dta)                                                            ## 1132077608 bytes
object.size(x = dta_t)                                                          ## 1132078424 bytes

range(dta_t$DT)                                                                 ## earliest date vs most recent
uniqueN(dta_t$STATION)                                                          ## number of different stations
uniqueN(dta_t$ELEMENT)                                                          ## number of different elements? im not sure what an "element" is

## preparing everything

## extracting time components
dta_t[, year := as.integer(format(DT, "%Y"))]                                   ## year
dta_t[, month := as.integer(format(DT, "%m"))]                                  ## month
dta_t[, day := as.integer(format(DT, "%d"))]                                    ## day

## indicators :3
dta_t[, rain_day := VALUE > 0]                                                  ## rainy day for where value is positive
dta_t[, no_q := is.na(QUALITY)]                                                 ## missing quality

thr <- quantile(dta_t$VALUE, 0.999, na.rm = TRUE)                               ## 99 percentile, i think it's a pretty cool thing to show, 
                                                                                ## like top 10 most extreme rain ever
                                                                                ## thr is for threshhold

dta_t[, extreme := VALUE > thr]        

## deleting X
dta_t[, X := NULL]

## choosing stations

## so basically there's a thing called variance that familiar with and it makes things interesting
## so high variance means theres a lot of different things happening (interesting results)
## and low variance means a thing is stable, no ups/downs or limited amount of such (boring results, boooooo)
## so anyway i'll be choosing high variance stations :3

dt_stat <- dta_t[, .(
  var_prec = var(VALUE, na.rm = TRUE)),
  by = STATION]

st_sel <- dt_stat[order(-var_prec)][1:6, STATION]

## choosing elements
el_sel <- unique(dta_t$ELEMENT)[1:3]

## plots

## plot A - daily time series
p1 <- ggplot(data = dta_t[STATION %in% st_sel],
             mapping = aes(x = DT, y = VALUE)) +
  geom_line(alpha = 0.6) +
  facet_wrap(~ STATION, ncol = 2) +
  theme_minimal()
  
p1

## i noticed that 2 stations lack data prior to 2020 and one prior to 2022 even

## plot B - monthly aggregation
dt_month <- dta_t[
  STATION %in% st_sel,
  .(prec_month = sum(VALUE, na.rm = TRUE)),
  by = .(STATION, year, month)
]

p2 <- ggplot(data = dt_month,
             mapping = aes(x = factor(month), y = prec_month, group = year)) +
  geom_line(alpha = 0.6) +
  facet_wrap(~ STATION) +
  theme_minimal()

p2

