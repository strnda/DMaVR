# -------------  Plot 3  ---------
# Extreme events
top <- quantile(dta_cl$VALUE, 0.99)
# With this we get tom 1% 

# Extreme values:
dta_ext <- dta_cl[STATION %in% st_sel & VALUE > top]

p3 <- ggplot(dta_cl[STATION %in% st_sel], aes(x = DT, y = VALUE))+
  geom_line() +
  # for extremas:
  geom_point(data = dta_ext, aes(x = DT, y = VALUE), colour = "red") +
  # threshold line
  geom_hline(yintercept = top, colour = "blue") +
  facet_wrap(~ STATION, scales = "free_y")+
  labs(
    title = "Extreme precipitation events (top 1%)",
    x = "Time",
    y = "Precipitation"
  )

# This plot looks crazy, so I'll improvise and do one more plot but with 
# monthly extreme values per station

# monthly extremas per station
dt_month_ext <- dta_cl[
  STATION %in% st_sel,
  .(max_val = max(VALUE)),
  by = .(STATION, month)
]

monthly_ext <- ggplot(dt_month_ext, aes(x = month, y = max_val)) +
  geom_line() +
  geom_point(colour = "red") +
  facet_wrap(~ STATION, scales = "free_y") +
  labs(
    title = "Monthly extreme precipitation per station",
    x = "Month",
    y = "Maximum precipitation"
  )

# This looks way better, we can clearly see monthly exteme

# -----  Plot 4 -------
# Distribution plots

p4 <- ggplot(
  dta_cl[STATION %in% st_sel],
  aes(x = STATION, y = VALUE)
) +
  geom_boxplot() +
  scale_y_log10() +
  labs(
    title = "Distribution of precipitation across stations",
    x = "Station",
    y = "Precipitation"
  ) 
# I decided to complare precipitation actoss stations with boxplots.
# I used log scale because data contains many small values and zeros
# But this plot can be misleading because log can't properly represent zeros

# We have recquirement: One plot must compare distributions across elements.
# but we have one element, so I'll do zero vs non zero value plot

p5 <- ggplot(
  dta_cl[STATION %in% st_sel],
  aes(x = VALUE, fill = pos_value)
) +
  geom_histogram(bins = 50, position = "identity", alpha = 0.6) +
  labs(
    title = "Distribution of precipitation (zero vs non-zero)",
    x = "Value",
    y = "Count"
  )

# ------------- Plot 6 -----------
# Clean quality plots
# originally I thought suspicious values would be under 0 but we don't have that type of values
# so I decided to define suspicious values as values that are extremly high
# top 0.5% = suspicious
thr_sus <- quantile(dta_cl$VALUE, 0.995)

p6 <- ggplot(dta_cl[STATION %in% st_sel], aes(x = DT, y = VALUE)) +
  geom_line()+
  geom_point(data = dta_cl[STATION %in% st_sel & VALUE > thr_sus],
             aes(x = DT, y = VALUE),
             colour = "red") +
  facet_wrap(~ STATION, scales = "free_y") +
  labs(title = "Suspicious precipitation over time",
       x = "Time",
       y = "precipitation")

