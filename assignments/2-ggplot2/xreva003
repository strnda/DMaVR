unique(dta_t$STATION)
#There are 431 stations
unique(dta_t$ELEMENT)

library(lubridate)

dta_t[, DT := as.POSIXct(DT)]
dta_t[, year  := year(DT)]
dta_t[, month := month(DT)]
dta_t[, day   := day(DT)]

#I'll remove na's from value, and impossible values
dta_cl <- dta_t
dta_cl <- dta_cl[!is.na(VALUE)]
dta_cl[, pos_value := VALUE > 0]
dta_cl[, qual_missing := is.na(QUALITY)]
dta_cl[, sus := VALUE < 0 | VALUE > 200]

unique(dta_cl$pos_value)
unique(dta_cl$qual_missing)
unique(dta_cl$sus)

#station selection:
# I went with the rule: stations with the largest number of non-zero values
# Because, it seems the easiest and I know for sure how to do it
# stations with highest value has the most rainfall but doesn't include stations with
# low precipitation.
# stations with highest precipitation show more patterns which is very nice for plotting

st_rank <- dta_t[, .(n_nonzero = sum(VALUE > 0, na.rm = TRUE)), by = STATION]
st_sel <- st_rank[order(-n_nonzero)][1:6, STATION]

#let's check data out
summary(dta_t[STATION %in% st_sel])
# max is 47 and mean is ~0.15 which means we still have lot's of low and zero numbers

