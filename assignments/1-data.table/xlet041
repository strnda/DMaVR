# Create station-level summary
st_sum <- dta_t[, .(
  n_rows = .N,                           # total number of rows
  mean_value = mean(VALUE, na.rm = TRUE),
  sd_value = sd(VALUE, na.rm = TRUE),
  min_value = min(VALUE, na.rm = TRUE),
  max_value = max(VALUE, na.rm = TRUE),
  n_nonzero = sum(VALUE != 0, na.rm = TRUE),   # number of rows with VALUE > 0
  n_suspicious = sum(suspicious, na.rm = TRUE) # number of suspicious rows
), by = STATION]

# sap xep order by STATION
st_sum <- st_sum[order(STATION)]

# Inspect
head(st_sum)
## element summary
# Create element-level summary
el_sum <- dta_t[, .(
  n_rows = .N,                          # number of rows per ELEMENT
  n_stations = uniqueN(STATION),        # number of stations reporting this ELEMENT
  mean_value = mean(VALUE, na.rm = TRUE),
  sd_value = sd(VALUE, na.rm = TRUE),
  prop_missing = sum(is.na(VALUE)) / .N, # proportion of missing VALUEs
  n_flagged = sum(FALSE),               # FLAG is empty → 0
  n_questionable = sum(suspicious, na.rm = TRUE) # number of suspicious VALUEs
), by = ELEMENT]

# Optional: order by ELEMENT
el_sum <- el_sum[order(ELEMENT)]

# Inspect
head(el_sum)
## merge task
# Ensure DT is datetime
dta_t[, DT := as.POSIXct(DT)]

# Create non-zero hourly data
nz_hourly <- dta_t[VALUE > 0, .(DT, VALUE)]

# Helper table
dt <- data.table(
  DT = seq(from = as.POSIXct("2018-01-01 00:00:00"),
           to   = as.POSIXct("2026-01-01 00:00:00"),
           by   = "hour"),
  VALUE = 0
)

# Merge
merged <- merge(dt, nz_hourly, by = "DT", all.x = TRUE)

